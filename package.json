{
  "name": "create-tags",
  "version": "0.0.0",
  "description": "Create multiple tags",
  "main": "/src/index.ts",
  "scripts": {
    "prepare": "husky",
    "start": "npm install && npm run build",
    "build": "esbuild ./src --outfile=dist/index.js --bundle --platform=node",
    "test": "jest .",
    "test:watch": "jest . --watch",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "check-types": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "all": "npm run check-types && npm run lint:fix -- --max-warnings=0 && npm run format && npm run build"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "JavaScript"
  ],
  "author": "Brady Clifford",
  "license": "ISC",
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{js,yml,json,ts,md}": [
      "prettier --write"
    ],
    "*.{yml,yaml}": [
      "yamllint"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@jest/types": "^30.4.1",
    "@octokit/types": "^16.0.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "yaml-lint": "^1.7"
  },
  "overrides": {
    "undici": "^8.5.0",
    "json-with-bigint": "^3.5.8",
    "js-yaml": "^4.2.0"
  }
}
